{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm start",
            "cwd": "${workspaceFolder}",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "name": "Attach to Remote",
            "type": "node",
            "request": "attach",
            "address": "127.0.0.1",
            "localRoot": "${workspaceFolder}",
            "port": 8080,
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}
