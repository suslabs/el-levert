{
    "name": "el-levert",
    "main": "index.js",
    "type": "module",
    "private": true,
    "scripts": {
        "test": "vitest run",
        "coverage": "vitest run --coverage",
        "start": "node --experimental-websocket --no-warnings=ExperimentalWarning index.js",
        "format": "prettier --config .prettierrc --ignore-path .prettierignore --write **/*.{js,cjs,json}",
        "lint": "eslint . --config .eslintrc.json --ignore-path .gitignore --ext .js",
        "importer": "cross-env MOCK_MAP_PATH=\"./scripts/importer/mock/mock-map.json\" node --no-warnings=ExperimentalWarning --loader \"./scripts/mock/mock-loader.js\" ./scripts/importer/importer.js",
        "proxyserv": "node ./scripts/vscode/proxyserv.cjs"
    },
    "dependencies": {
        "@leeoniya/ufuzzy": "^1.0.19",
        "ajv": "^8.20.0",
        "axios": "^1.16.0",
        "chrono-node": "^2.9.1",
        "discord.js": "^14.26.4",
        "isolated-vm": "^5.0.4",
        "re2": "^1.24.0",
        "sqlite3": "^5.1.7",
        "generic-pool": "^3.9.0",
        "winston": "^3.19.0"
    },
    "optionalDependencies": {
        "vm2": "^3.11.2"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^7.28.6",
        "@babel/plugin-syntax-import-assertions": "^7.28.6",
        "@vitest/coverage-v8": "^4.1.5",
        "cross-env": "^10.1.0",
        "eslint": "^8.57.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "prettier": "^3.8.3",
        "vitest": "^4.1.5"
    }
}
